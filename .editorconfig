# https://editorconfig.org — one consistent style across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
# Markdown can use trailing spaces for hard line breaks — don't strip them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

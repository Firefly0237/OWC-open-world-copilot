# Copy to .env and fill in ONLY when you wire a real provider.
# P0 runs fully offline with the mock provider — no keys needed.
OPENAI_BASE_URL=https://<openai-compatible-provider>
OPENAI_API_KEY=sk-...
FRONTIER_BASE_URL=https://<frontier-provider>
FRONTIER_API_KEY=sk-...

# Set this for any real-mode API deployment; requests must send X-API-Key.
OWCOPILOT_API_KEY=<choose-a-service-api-key>

# --- Service safety / cost guardrails ---
OWCOPILOT_RATE_LIMIT_PER_MIN=60
OWCOPILOT_RATE_LIMIT_BACKEND=memory
OWCOPILOT_REDIS_URL=redis://redis:6379/0
OWCOPILOT_LLM_MAX_RETRIES=2
OWCOPILOT_LLM_RETRY_BACKOFF_SEC=0.25
OWCOPILOT_PROVIDER_TIMEOUT_SEC=30

# --- World Bible input budgets ---
OWCOPILOT_MAX_WORLDBIBLE_CHARS=200000
OWCOPILOT_MAX_WORLDBIBLE_ENTITIES=500
OWCOPILOT_MAX_WORLDBIBLE_RELATIONS=2000
OWCOPILOT_MAX_WORLDBIBLE_FIELD_CHARS=2000

# --- P3: Unreal Engine landing (only for `run_ue_demo.py --ue` against a real editor) ---
# All optional; defaults shown. Never hard-code these in source — the bridge reads them here.
OWCOPILOT_UE_RC_URL=http://<ue-host>:30010
# Object path of the QuestCopilot helper exposed to Remote Control (see scripts/ue/quest_copilot_helper.py)
OWCOPILOT_UE_HELPER=/Game/<QuestCopilotHelperPath>
OWCOPILOT_UE_UPSERT_FN=UpsertQuestRow
OWCOPILOT_UE_READ_FN=ReadQuestRow
# DataTable asset the rows land into (configured on the UE side / helper)
OWCOPILOT_UE_TABLE=/Game/<QuestTableAssetPath>
